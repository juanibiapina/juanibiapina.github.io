---
import IconHash from "@/assets/icons/IconHash.svg";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;
---

<li>
  <a
    href={`/tags/${tag}/`}
    class:list={[
      "inline-flex items-center gap-0.5 opacity-70 hover:text-accent hover:opacity-100",
      "focus-visible:text-accent",
      { "text-sm": size === "sm" },
      { "text-sm": size === "lg" },
    ]}
  >
    <IconHash
      class:list={[
        "size-4",
      ]}
    />
    {tagName}
  </a>
</li>
