---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={[{ "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div class="mx-auto max-w-2xl px-4">
    <hr class="border-border" />
  </div>
  <div
    class:list={[
      "mx-auto max-w-2xl px-4",
      "py-6 sm:py-4",
      "flex flex-col items-center justify-between gap-2 sm:flex-row-reverse",
    ]}
  >
    <Socials />
    <div class="text-sm opacity-80">
      <a
        href="https://github.com/juanibiapina/juanibiapina.github.io"
        class="hover:text-accent"
        target="_blank"
        rel="noopener noreferrer"
      >
        Content CC BY 4.0 · Code MIT
      </a>
    </div>
  </div>
</footer>
