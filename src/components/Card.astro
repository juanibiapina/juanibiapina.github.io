---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import { getReadingTime } from "@/utils/getReadingTime";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import { SITE } from "@/config";

dayjs.extend(utc);
dayjs.extend(timezone);

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, body, data, filePath } = Astro.props;

const {
  title,
  description,
  ogImage,
  pubDatetime,
  modDatetime,
  timezone: postTimezone,
} = data;

const thumbnailSrc = typeof ogImage === "string" ? ogImage : ogImage?.src;
const thumbnailWidth = typeof ogImage === "string" ? undefined : ogImage?.width;
const thumbnailHeight = typeof ogImage === "string" ? undefined : ogImage?.height;

const readingTime = body ? getReadingTime(body) : undefined;

const isModified = modDatetime && modDatetime > pubDatetime;
const datetime = dayjs(isModified ? modDatetime : pubDatetime).tz(
  postTimezone || SITE.timezone
);
const date = datetime.format("YYYY-MM-DD");
---

<li class="card-item">
  <a href={getPath(id, filePath)} class="card-link">
    {
      thumbnailSrc && (
        <img
          class="card-image"
          src={thumbnailSrc}
          alt=""
          loading="lazy"
          decoding="async"
          width={thumbnailWidth}
          height={thumbnailHeight}
        />
      )
    }
    <span class="card-date">
      <time datetime={datetime.toISOString()}>{date}</time>
      {readingTime && <span> · {readingTime} min</span>}
    </span>
    <Heading
      class="card-title"
      style={{ viewTransitionName: slugifyStr(title) }}
    >
      {title}
    </Heading>
    {description && <p class="card-desc">{description}</p>}
  </a>
</li>

<style>
  .card-item {
    list-style: none;
  }

  .card-link {
    display: block;
    border: 1px solid var(--border);
    padding: 1.2rem 1.4rem 1rem;
    text-decoration: none;
    transition:
      border-color 0.25s,
      box-shadow 0.25s;
  }

  .card-image {
    display: block;
    width: calc(100% + 2.8rem);
    margin: -1.2rem -1.4rem 0.9rem;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-bottom: 1px solid var(--border);
    background: var(--muted);
  }

  .card-link:hover {
    border-color: var(--border-hover);
    box-shadow: 0 0 24px color-mix(in srgb, var(--link) 10%, transparent);
  }

  .card-date {
    display: block;
    font-size: 0.7rem;
    color: var(--foreground);
    opacity: 0.55;
    letter-spacing: 0.06em;
    margin-bottom: 0.4rem;
  }

  .card-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--link);
    line-height: 1.4;
    margin: 0 0 0.4rem;
  }

  .card-desc {
    font-size: 0.8rem;
    color: var(--foreground);
    opacity: 0.7;
    line-height: 1.55;
    margin: 0;
  }
</style>
