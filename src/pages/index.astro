---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import avatar from "@/assets/avatar.jpg";
import { SITE } from "@/config";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.title,
    url: SITE.website,
    description: SITE.desc,
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: SITE.author,
    url: SITE.profile,
    sameAs: [
      "https://github.com/juanibiapina",
      "https://x.com/IbiapinaJuan",
      "https://www.linkedin.com/in/juan-i-10025313/",
    ],
  },
];
---

<Layout>
  <Fragment slot="head">
    {
      structuredData.map(data => (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(data)}
        />
      ))
    }
  </Fragment>
  <Header />
  <main id="main-content" class="mx-auto w-full max-w-2xl px-4">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <div class="flex flex-col items-center gap-6 sm:flex-row sm:items-start">
        <Image
          src={avatar}
          alt="Juan Ibiapina"
          class="size-40 flex-shrink-0 rounded-full"
          width={160}
          height={160}
          widths={[160, 320]}
          sizes="160px"
          loading="eager"
          fetchpriority="high"
        />
        <div>
          <div class="my-2 flex items-center gap-2 sm:my-0">
            <h1 class="inline-block text-2xl font-bold sm:text-3xl">
              Hi, I'm Juan
            </h1>
            <a
              target="_blank"
              href="/rss.xml"
              class="inline-block"
              aria-label="rss feed"
              title="RSS Feed"
            >
              <IconRss
                width={20}
                height={20}
                class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
              />
              <span class="sr-only">RSS Feed</span>
            </a>
          </div>
          <p class="mt-3">
            Software engineer into agentic coding, the command line, and
            climbing. I use and extend <a href="https://pi.dev" class="text-accent underline underline-offset-4 decoration-dotted">pi</a> daily.
            I put my energy into way too many things.
          </p>
          <div class="mt-3">
            <Socials />
          </div>
        </div>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul class="mt-4 flex flex-col gap-4">
            {featuredPosts.map((data, index) => (
              <Card variant="h3" eager={index === 0} {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6" aria-labelledby="recent-posts-heading">
          <h2 id="recent-posts-heading" class="sr-only">Recent posts</h2>
          <ul class="flex flex-col gap-4">
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && (
                  <Card
                    variant="h3"
                    eager={featuredPosts.length === 0 && index === 0}
                    {...data}
                  />
                )
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/" class="text-sm opacity-55 hover:opacity-100">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>
