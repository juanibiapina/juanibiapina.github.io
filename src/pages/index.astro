---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.title,
    url: SITE.website,
    description: SITE.desc,
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: SITE.author,
    url: SITE.profile,
    sameAs: [
      "https://github.com/juanibiapina",
      "https://x.com/IbiapinaJuan",
      "https://www.linkedin.com/in/juan-i-10025313/",
    ],
  },
];
---

<Layout>
  <Fragment slot="head">
    {
      structuredData.map(data => (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(data)}
        />
      ))
    }
  </Fragment>
  <Header />
  <main id="main-content" data-layout="index" class="mx-auto w-full max-w-3xl px-4">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <div class="flex flex-col items-center gap-6 sm:flex-row sm:items-start">
        <img
          src="https://github.com/juanibiapina.png"
          alt="Juan Ibiapina"
          class="size-40 flex-shrink-0 rounded-full"
          width="160"
          height="160"
        />
        <div>
          <div class="my-2 flex items-center gap-2 sm:my-0">
            <h1 class="inline-block text-2xl font-bold sm:text-3xl">
              Hi, I'm Juan
            </h1>
            <a
              target="_blank"
              href="/rss.xml"
              class="inline-block"
              aria-label="rss feed"
              title="RSS Feed"
            >
              <IconRss
                width={20}
                height={20}
                class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
              />
              <span class="sr-only">RSS Feed</span>
            </a>
          </div>
          <p class="mt-3">
            Software engineer, language enthusiast, and open source contributor.
            I write about programming languages, tools, and whatever else
            catches my attention.
          </p>
          <div class="mt-3">
            <Socials />
          </div>
        </div>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
